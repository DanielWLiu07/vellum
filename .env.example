# Shared secret used to verify capability tokens minted by the host app.
# The host app signs tokens with the SAME secret. Must be high-entropy (32+ bytes).
# Generate: openssl rand -hex 32
VELLUM_TOKEN_SECRET=

# Space-separated list of origins allowed to embed /embed in an <iframe>.
# Example: "https://app.hosacanada.org https://staging.hosa-member.ca"
# Leave unset to allow only same-origin framing ('self').
VELLUM_FRAME_ANCESTORS=

# Enables the public /api/demo-token endpoint and the live demo on the landing
# page. Set to "1" for the portfolio deployment, leave empty in production
# integrations where only the host app should mint tokens.
VELLUM_DEMO_MODE=1

# --- Dashboard upload storage (optional) ---------------------------------
# Dashboard-mode uploads default to an in-memory store (ephemeral — fine for
# the demo). Set ALL FOUR vars below to persist uploads in Cloudflare R2
# (S3-compatible). Leave any unset to stay on the in-memory backend.
# Works against AWS S3 too — just point R2_ENDPOINT at the S3 endpoint.
#   R2_ENDPOINT example: https://<account-id>.r2.cloudflarestorage.com
#   R2_BUCKET may also be provided as R2_BUCKET_NAME (some provisioners use that).
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
