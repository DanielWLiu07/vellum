# Shared secret used to verify capability tokens minted by the host app.
# The host app signs tokens with the SAME secret. Must be high-entropy (32+ bytes).
# Generate: openssl rand -hex 32
VELLUM_TOKEN_SECRET=

# Space-separated list of origins allowed to embed /embed in an <iframe>.
# Example: "https://app.hosacanada.org https://staging.hosa-member.ca"
# Leave unset to allow only same-origin framing ('self').
VELLUM_FRAME_ANCESTORS=

# Enables the public /api/demo-token endpoint and the live demo on the landing
# page. Set to "1" for the portfolio deployment, leave empty in production
# integrations where only the host app should mint tokens.
VELLUM_DEMO_MODE=1
